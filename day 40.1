import time 
from functools import lru_cache 
 
@lru_cache(maxsize=None)
def powers(a,b):
    if a<0:
        return 1
    time.sleep(1)
    return a ** b 

print("2 to the power of 3 is:",powers(2,3))
print("2 to the power of 3 is:",powers(2,3))
print("2 to the power of 3 is:",powers(2,4))
print("2 to the power of 3 is:",powers(2,5))
print("2 to the power of 3 is:",powers(2,6))
